---
import BaseLayout from '../../layouts/BaseLayout.astro';
import AuthorBio from '../../components/AuthorBio.astro';
import { getCollection, render } from 'astro:content';

export async function getStaticPaths() {
  const posts = await getCollection('blog');
  return posts.map(post => ({
    params: { slug: post.id },
    props: { post },
  }));
}

const { post } = Astro.props;
const { Content } = await render(post);

// 関連記事（同タグ重複数の多い順、上位3件）
const allPosts = await getCollection('blog');
const related = allPosts
  .filter(p => p.id !== post.id && p.data.tags.some((t: string) => post.data.tags.includes(t)))
  .map(p => ({
    post: p,
    overlap: p.data.tags.filter((t: string) => post.data.tags.includes(t)).length,
  }))
  .sort((a, b) => b.overlap - a.overlap || b.post.data.pubDate.valueOf() - a.post.data.pubDate.valueOf())
  .slice(0, 3)
  .map(x => x.post);
---

<BaseLayout
  title={post.data.title}
  description={post.data.description}
  breadcrumbs={[
    { name: 'ホーム', url: '/' },
    { name: 'ブログ', url: '/blog' },
    { name: post.data.title, url: `/blog/${post.id}` },
  ]}
>
  <article class="max-w-2xl">
    <header class="mb-8">
      <div class="flex flex-wrap gap-2 mb-3">
        {post.data.tags.map((tag: string) => (
          <a href={`/blog/tag/${encodeURIComponent(tag)}/`} class="text-xs bg-sky-100 text-sky-700 hover:bg-sky-200 px-2 py-1 rounded-full transition-colors">{tag}</a>
        ))}
      </div>
      <h1 class="text-3xl font-bold text-gray-900 leading-tight mb-3">{post.data.title}</h1>
      <p class="text-gray-400 text-sm">
        投稿日：{post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
        {post.data.updatedDate && (
          <>　更新日：{post.data.updatedDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}</>
        )}
      </p>
    </header>

    <div class="prose prose-gray prose-sky max-w-none">
      <Content />
    </div>

    <AuthorBio />

    {related.length > 0 && (
      <section class="mt-10 pt-8 border-t border-gray-200">
        <h2 class="text-lg font-bold text-gray-900 mb-4 flex items-center gap-2">
          <span class="text-sky-600">📚</span> 関連記事
        </h2>
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          {related.map(r => (
            <a href={`/blog/${r.id}`}
              class="group bg-sky-50 hover:bg-sky-100 rounded-xl p-4 border border-sky-100 transition-colors">
              <p class="text-xs text-gray-400 mb-1">{r.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}</p>
              <p class="font-bold text-gray-900 group-hover:text-sky-700 text-sm leading-snug mb-2">{r.data.title}</p>
              <p class="text-xs text-gray-500 line-clamp-2">{r.data.description}</p>
            </a>
          ))}
        </div>
      </section>
    )}

    <div class="mt-12 bg-gray-50 border border-gray-200 rounded-xl p-5">
      <p class="text-gray-400 text-xs">
        ※ 本記事の情報は執筆時点（2026年）のものです。税額・料金等は法改正・市場変動により変更される場合があります。最新情報は国税庁・各都道府県・各社の公式サイトをご確認ください。本記事を参考にした結果生じた損害について当サイトは責任を負いません。
      </p>
    </div>

    <div class="mt-6 flex gap-4">
      <a href="/blog" class="text-sky-600 hover:underline text-sm font-medium">← 記事一覧に戻る</a>
      <a href="/tools" class="text-sky-600 hover:underline text-sm font-medium">無料ツールを使う →</a>
    </div>
  </article>
</BaseLayout>
