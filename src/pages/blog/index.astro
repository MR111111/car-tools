---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime());
---

<BaseLayout
  title="ブログ｜自動車コスト・税金・車検・EV解説"
  description="ガソリン代・自動車税・車検費用・EV・タイヤ・カーローンなど、クルマにまつわるお金の知識をわかりやすく解説するブログです。"
  breadcrumbs={[
    { name: 'ホーム', url: '/' },
    { name: 'ブログ', url: '/blog' },
  ]}
>
  <h1 class="text-3xl font-bold text-white mb-2">ブログ記事一覧</h1>
  <p class="text-slate-400 mb-10">クルマにかかるお金をわかりやすく解説。全{posts.length}記事。</p>

  <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
    {posts.map(post => (
      <a
        href={`/blog/${post.id}`}
        class="bg-slate-800 border border-slate-700 rounded-xl p-5 hover:border-sky-500 hover:bg-slate-700 transition-all group"
      >
        <p class="text-slate-500 text-xs mb-2">
          {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
        </p>
        <h2 class="text-white font-semibold leading-snug group-hover:text-sky-400 transition-colors mb-2">
          {post.data.title}
        </h2>
        <p class="text-slate-400 text-sm line-clamp-2">{post.data.description}</p>
        {post.data.tags.length > 0 && (
          <div class="flex flex-wrap gap-1 mt-3">
            {post.data.tags.map((tag: string) => (
              <span class="text-xs bg-slate-700 text-sky-300 px-2 py-0.5 rounded-full">{tag}</span>
            ))}
          </div>
        )}
      </a>
    ))}
  </div>
</BaseLayout>
