---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const tools = [
  {
    href: '/tools/gasoline-cost',
    icon: '⛽',
    title: 'ガソリン代計算',
    desc: '月間走行距離・燃費・ガソリン単価から月額・年額を瞬時に計算',
  },
  {
    href: '/tools/ev-vs-gasoline',
    icon: '⚡',
    title: 'EV vs ガソリン比較',
    desc: '電気自動車とガソリン車の燃料コストを10年間で徹底比較',
  },
  {
    href: '/tools/jidosha-zei',
    icon: '🏛️',
    title: '自動車税計算',
    desc: '排気量・登録年数から自動車税（種別割）と重量税を自動算出',
  },
  {
    href: '/tools/shaken-cost',
    icon: '🔧',
    title: '車検費用シミュレーター',
    desc: '法定費用＋整備費用の内訳を車種・重量・車検場所別に試算',
  },
  {
    href: '/tools/tire-size',
    icon: '🚗',
    title: 'タイヤサイズチェッカー',
    desc: 'サイズ変更後の外径差・速度メーター誤差・互換性を即チェック',
  },
  {
    href: '/tools/car-loan',
    icon: '💴',
    title: '残価ローン比較',
    desc: '通常ローンと残価設定ローンの月額・総支払額をわかりやすく比較',
  },
];
---

<BaseLayout
  title="CarTools｜自動車コスト無料計算ツール"
  description="ガソリン代・自動車税・車検費用・EV比較など自動車に関するコスト計算ツールと解説記事を無料で提供。スマホでもサクサク動く計算機。"
>
  <!-- Hero -->
  <section class="text-center py-12 mb-12">
    <h1 class="text-4xl md:text-5xl font-bold text-white mb-4 leading-tight">
      自動車コストを<br class="md:hidden"/><span class="text-sky-400">正確に</span>把握しよう
    </h1>
    <p class="text-slate-400 text-lg max-w-xl mx-auto">
      ガソリン代・税金・車検・ローン比較まで、クルマにかかるすべてのコストを無料で計算。
    </p>
  </section>

  <!-- Tools Grid -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-white mb-6 flex items-center gap-2">
      <span class="w-1 h-7 bg-sky-400 rounded-full inline-block"></span>
      無料計算ツール
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map(tool => (
        <a
          href={tool.href}
          class="bg-slate-800 border border-slate-700 rounded-xl p-5 hover:border-sky-500 hover:bg-slate-700 transition-all group"
        >
          <div class="text-3xl mb-3">{tool.icon}</div>
          <h3 class="text-white font-bold text-lg mb-1 group-hover:text-sky-400 transition-colors">{tool.title}</h3>
          <p class="text-slate-400 text-sm leading-relaxed">{tool.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-white flex items-center gap-2">
        <span class="w-1 h-7 bg-sky-400 rounded-full inline-block"></span>
        最新記事
      </h2>
      <a href="/blog" class="text-sky-400 text-sm hover:underline">すべて見る →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {posts.map(post => (
        <a
          href={`/blog/${post.id}`}
          class="bg-slate-800 border border-slate-700 rounded-xl p-5 hover:border-sky-500 hover:bg-slate-700 transition-all"
        >
          <p class="text-slate-500 text-xs mb-2">
            {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h3 class="text-white font-semibold leading-snug hover:text-sky-400 transition-colors">{post.data.title}</h3>
          <p class="text-slate-400 text-sm mt-2 line-clamp-2">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
