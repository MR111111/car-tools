---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .sort((a, b) => b.data.pubDate.getTime() - a.data.pubDate.getTime())
  .slice(0, 6);

const tools = [
  {
    href: '/tools/gasoline-cost',
    icon: '⛽',
    title: 'ガソリン代計算',
    desc: '月間走行距離・燃費・ガソリン単価から月額・年額を瞬時に計算',
    color: 'bg-orange-50 border-orange-200 hover:border-orange-400',
    iconBg: 'bg-orange-100',
  },
  {
    href: '/tools/ev-vs-gasoline',
    icon: '⚡',
    title: 'EV vs ガソリン比較',
    desc: '電気自動車とガソリン車の燃料コストを10年間で徹底比較',
    color: 'bg-sky-50 border-sky-200 hover:border-sky-400',
    iconBg: 'bg-sky-100',
  },
  {
    href: '/tools/jidosha-zei',
    icon: '🏛️',
    title: '自動車税計算',
    desc: '排気量・登録年数から自動車税（種別割）と重量税を自動算出',
    color: 'bg-violet-50 border-violet-200 hover:border-violet-400',
    iconBg: 'bg-violet-100',
  },
  {
    href: '/tools/shaken-cost',
    icon: '🔧',
    title: '車検費用シミュレーター',
    desc: '法定費用＋整備費用の内訳を車種・重量・車検場所別に試算',
    color: 'bg-green-50 border-green-200 hover:border-green-400',
    iconBg: 'bg-green-100',
  },
  {
    href: '/tools/tire-size',
    icon: '🚗',
    title: 'タイヤサイズチェッカー',
    desc: 'サイズ変更後の外径差・速度メーター誤差・互換性を即チェック',
    color: 'bg-slate-50 border-slate-200 hover:border-slate-400',
    iconBg: 'bg-slate-100',
  },
  {
    href: '/tools/car-loan',
    icon: '💴',
    title: '残価ローン比較',
    desc: '通常ローンと残価設定ローンの月額・総支払額をわかりやすく比較',
    color: 'bg-yellow-50 border-yellow-200 hover:border-yellow-400',
    iconBg: 'bg-yellow-100',
  },
];
---

<BaseLayout
  title="CarMoneyLab｜自動車コスト無料計算ツール"
  description="ガソリン代・自動車税・車検費用・EV比較など自動車に関するコスト計算ツールと解説記事を無料で提供。スマホでもサクサク動く計算機。"
>
  <!-- Hero -->
  <section class="text-center py-14 mb-12 bg-gradient-to-b from-sky-50 to-gray-50 -mx-4 px-4 rounded-2xl">
    <div class="inline-flex items-center gap-2 bg-sky-100 text-sky-700 text-xs font-semibold px-3 py-1 rounded-full mb-4">
      🚗 自動車コスト計算ツール 無料
    </div>
    <h1 class="text-4xl md:text-5xl font-bold text-gray-900 mb-4 leading-tight">
      クルマのお金を<br class="md:hidden"/><span class="text-sky-600">かんたんに</span>把握しよう
    </h1>
    <p class="text-gray-500 text-lg max-w-xl mx-auto mb-8">
      ガソリン代・税金・車検・ローン比較まで、クルマにかかるすべてのコストを無料で計算。
    </p>
    <a href="/tools" class="inline-flex items-center gap-2 bg-sky-600 text-white font-bold px-6 py-3 rounded-xl hover:bg-sky-700 transition-colors shadow-md shadow-sky-200">
      無料ツールを使う →
    </a>
  </section>

  <!-- Tools Grid -->
  <section class="mb-16">
    <h2 class="text-2xl font-bold text-gray-900 mb-6 flex items-center gap-2">
      <span class="w-1 h-7 bg-sky-500 rounded-full inline-block"></span>
      無料計算ツール
    </h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {tools.map(tool => (
        <a
          href={tool.href}
          class={`border rounded-xl p-5 transition-all group shadow-sm hover:shadow-md ${tool.color}`}
        >
          <div class={`inline-flex items-center justify-center w-12 h-12 rounded-xl text-2xl mb-3 ${tool.iconBg}`}>
            {tool.icon}
          </div>
          <h3 class="text-gray-900 font-bold text-lg mb-1 group-hover:text-sky-600 transition-colors">{tool.title}</h3>
          <p class="text-gray-500 text-sm leading-relaxed">{tool.desc}</p>
        </a>
      ))}
    </div>
  </section>

  <!-- Latest Blog Posts -->
  <section>
    <div class="flex items-center justify-between mb-6">
      <h2 class="text-2xl font-bold text-gray-900 flex items-center gap-2">
        <span class="w-1 h-7 bg-sky-500 rounded-full inline-block"></span>
        最新記事
      </h2>
      <a href="/blog" class="text-sky-600 text-sm font-medium hover:underline">すべて見る →</a>
    </div>
    <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
      {posts.map(post => (
        <a
          href={`/blog/${post.id}`}
          class="bg-white border border-gray-200 rounded-xl p-5 hover:border-sky-400 hover:shadow-md transition-all"
        >
          <p class="text-gray-400 text-xs mb-2">
            {post.data.pubDate.toLocaleDateString('ja-JP', { year: 'numeric', month: 'long', day: 'numeric' })}
          </p>
          <h3 class="text-gray-900 font-semibold leading-snug hover:text-sky-600 transition-colors">{post.data.title}</h3>
          <p class="text-gray-500 text-sm mt-2 line-clamp-2">{post.data.description}</p>
        </a>
      ))}
    </div>
  </section>
</BaseLayout>
